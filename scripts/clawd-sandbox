#!/usr/bin/env bash
# Run clawd inside a Docker container so it can't see your home dir, SSH keys,
# shell history, or anything outside the current project. The project dir is
# bind-mounted at /workspace; .env is passed through.
#
# Usage:
#   scripts/clawd-sandbox            # run clawd in the current dir, sandboxed
#   scripts/clawd-sandbox --build    # force-rebuild the image first
set -eo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="clawd:latest"

ARGS=()
FORCE_BUILD=0
for arg in "$@"; do
    if [[ "$arg" == "--build" ]]; then
        FORCE_BUILD=1
    else
        ARGS+=("$arg")
    fi
done

if [[ $FORCE_BUILD -eq 1 ]] || ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
    docker build -t "$IMAGE" "$REPO_ROOT"
fi

# Pass .env through, but rewrite localhost / 127.0.0.1 to host.docker.internal
# so a host-side Ollama / Langfuse / vLLM is reachable from inside the container.
# The --add-host below makes host.docker.internal resolve on Linux too.
DOCKER_ENV=()
if [[ -f .env ]]; then
    TMP_ENV=$(mktemp)
    trap 'rm -f "$TMP_ENV"' EXIT
    sed -E 's#//(127\.0\.0\.1|localhost)#//host.docker.internal#g' .env > "$TMP_ENV"
    DOCKER_ENV=(--env-file "$TMP_ENV")
fi

exec docker run --rm -it \
    --add-host=host.docker.internal:host-gateway \
    -v "$PWD:/workspace" \
    -w /workspace \
    "${DOCKER_ENV[@]}" \
    "$IMAGE" "${ARGS[@]}"

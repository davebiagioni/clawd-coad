# Choose: openai (default, OpenAI-compatible endpoints) or anthropic (direct API).
CLAWD_PROVIDER=openai

# --- openai-compatible (default) ---
# Works with Ollama, vLLM, llama.cpp, OpenRouter, OpenAI, Together, Groq, etc.
CLAWD_BASE_URL=http://localhost:11434/v1
CLAWD_MODEL=qwen2.5-coder:7b
CLAWD_API_KEY=ollama

# --- anthropic (direct API; uses console.anthropic.com credits, NOT Max) ---
# CLAWD_PROVIDER=anthropic
# CLAWD_MODEL=claude-haiku-4-5-20251001    # cheap; great for tinkering
# CLAWD_MODEL=claude-sonnet-4-6            # the coding workhorse
# CLAWD_API_KEY=sk-ant-...

# Optional: where to checkpoint conversations. Defaults shown.
# CLAWD_DB_PATH=~/.clawd/sessions.db

# Optional: Langfuse tracing. Leave unset to disable.
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
